void out(pii ans)///已完成
{//以真分数形式输出一个答案;
	if(ans.Y==1)printf("%d\n",ans.X);
	else
	{
		if(ans.X%ans.Y<0)
		{
			printf("%d`",ans.X/ans.Y-1);
			printf("%d_%d\n",ans.X%ans.Y+ans.Y,ans.Y);
			return ;
		}
		if(ans.X/ans.Y)printf("%d`",ans.X/ans.Y);
		printf("%d_%d\n",ans.X%ans.Y,ans.Y);
	}
}
